generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role       String   @default("guest") // e.g., admin, guest, etc
  avatar_url String?
  members    Member[]
}

model Room {
  id               Int               @id @default(autoincrement())
  room_number      String            @unique
  floor            Int
  type             String
  price            Float
  status           String            @default("Available")
  features         String            // Storing as JSON string or comma-separated
  imageUrl         String
  members          Member[]
  maintenanceRooms MaintenanceRoom[]
}

model Member {
  id         Int        @id @default(autoincrement())
  user_id    Int
  user       User       @relation(fields: [user_id], references: [id])
  room_id    Int
  room       Room       @relation(fields: [room_id], references: [id])
  name       String
  phone      String
  status     String     @default("active")
  due_date   DateTime?
  id_number  String?
  avatar_url String?
  complaints Complaint[]
  payments   Payment[]
}

model Complaint {
  id             Int      @id @default(autoincrement())
  tracking_id    String   @unique
  member_id      Int
  member         Member   @relation(fields: [member_id], references: [id])
  category       String
  description    String
  photo_url      String?
  status         String   @default("pending")
  admin_response String?
}

model Payment {
  id                Int      @id @default(autoincrement())
  member_id         Int
  member            Member   @relation(fields: [member_id], references: [id])
  amount            Float
  payment_method    String
  status            String   @default("pending")
  payment_date      DateTime @default(now())
  due_date          DateTime @default(now())
  billing_month     String?
  gateway_reference String?
}

model MaintenanceSchedule {
  id               Int               @id @default(autoincrement())
  category         String
  date             DateTime
  time             String
  scope            String
  maintenanceRooms MaintenanceRoom[]
}

model MaintenanceRoom {
  maintenance_id Int
  maintenance    MaintenanceSchedule @relation(fields: [maintenance_id], references: [id])
  room_id        Int
  room           Room                @relation(fields: [room_id], references: [id])

  @@id([maintenance_id, room_id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  expiry_date DateTime
}

model BoardingHouseProfile {
  id                Int    @id @default(autoincrement())
  name              String
  description       String
  facilities        String
  maps_location_url String?
  contact_info      String
}
